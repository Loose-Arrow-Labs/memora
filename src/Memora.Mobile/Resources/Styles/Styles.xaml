<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="HeaderLabel" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInk}" />
    </Style>

    <Style x:Key="SubtleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInkDim}" />
    </Style>

    <Style x:Key="SectionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="1.5" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInkDim}" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInkDim}" />
    </Style>

    <Style x:Key="HintLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInkDim}" />
    </Style>

    <Style x:Key="ErrorLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource MemoraWarn}" />
    </Style>

    <Style x:Key="MetaKey" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInkDim}" />
    </Style>

    <Style x:Key="MetaValue" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInk}" />
        <Setter Property="LineBreakMode" Value="CharacterWrap" />
    </Style>

    <Style x:Key="SectionFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource MemoraPanel}" />
        <Setter Property="BorderColor" Value="{StaticResource MemoraBorder}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="MemoraEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource MemoraPanel2}" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInk}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource MemoraInkDim}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="MemoraEditor" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{StaticResource MemoraPanel2}" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInk}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource MemoraInkDim}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>

    <Style x:Key="MemoraPreviewEditor" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{StaticResource MemoraPanel2}" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInk}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>

    <Style x:Key="MemoraPicker" TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{StaticResource MemoraPanel2}" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInk}" />
        <Setter Property="TitleColor" Value="{StaticResource MemoraInkDim}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource MemoraPanel}" />
        <Setter Property="BarTextColor" Value="{StaticResource MemoraInk}" />
    </Style>

    <Style x:Key="MemoraButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource MemoraPanel2}" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInk}" />
        <Setter Property="BorderColor" Value="{StaticResource MemoraBorder}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <Style x:Key="MemoraPrimaryButton" TargetType="Button" BasedOn="{StaticResource MemoraButton}">
        <Setter Property="BackgroundColor" Value="#1F2C4D" />
        <Setter Property="BorderColor" Value="{StaticResource MemoraAccent}" />
    </Style>

    <Style x:Key="MemoraGhostButton" TargetType="Button" BasedOn="{StaticResource MemoraButton}">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style x:Key="MemoraSmallButton" TargetType="Button" BasedOn="{StaticResource MemoraButton}">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>

    <Style x:Key="MemoraSmallGhostButton" TargetType="Button" BasedOn="{StaticResource MemoraSmallButton}">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style x:Key="SavedItemFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource MemoraPanel2}" />
        <Setter Property="BorderColor" Value="{StaticResource MemoraBorder}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="BadgeFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource MemoraPanel}" />
        <Setter Property="BorderColor" Value="{StaticResource MemoraBorder}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="BadgeLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{StaticResource MemoraInkDim}" />
    </Style>

</ResourceDictionary>
